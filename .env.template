# Cifra — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env to git.

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Stability AI — https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-...

# KIE.AI image generation — https://kie.ai/dashboard
# Required for hero image generation (nano-banana-image-gen)
KIE_API_KEY=kie_...

# ── Google APIs ───────────────────────────────────────────────────────────────
# Google Places API — https://console.cloud.google.com
# Steps:
#   1. Go to https://console.cloud.google.com
#   2. Create project "Cifra" if not exists
#   3. Enable "Places API (New)" from API Library
#   4. Create API key under Credentials
#   5. Restrict key to Places API only
GOOGLE_PLACES_API_KEY=your_key_here

# ── Brand & Design ────────────────────────────────────────────────────────────
# Brandfetch — https://brandfetch.com/dashboard
BRANDFETCH_API_KEY=...

# ── Email Delivery ────────────────────────────────────────────────────────────
# Option A — Resend (recommended): https://resend.com/api-keys
RESEND_API_KEY=re_...

# Option B — SMTP (if not using Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Cifra <your@email.com>

# ── Scheduling ────────────────────────────────────────────────────────────────
# Calendly link — shown in onboarding emails
# Get from: https://calendly.com/app/scheduled_events/user/me
CALENDLY_URL=https://calendly.com/your-link
